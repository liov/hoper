{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "node": "v22.0.0",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "protoc": "node ../../proto/generate.js grpc-web",
    "wasm:build": "wasm-pack build ../../server/rust/wasm --target web",
    "wasm:link": "pnpm link ../../server/rust/wasm/pkg",
    "dev": "vite --config vite.config.ts --mode dev",
    "build": "run-p type-check build-only",
    "preview": "vite preview --config vite.config.ts --port 4173",
    "test:unit": "vitest --environment jsdom",
    "build-only": "vite build --config vite.config.ts --mode prod",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "diamon": "pnpm link @hopeio/utils"
  },
  "dependencies": {
    "@hopeio/utils": "link:../../../../../../sdk/pnpm/global/5/node_modules/@hopeio/utils",
    "axios": "^1.15.0",
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.6",
    "grpc-web": "^2.0.2",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "spark-md5": "^3.0.2",
    "vant": "^4.9.24",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "unplugin-vue-components": "32.0.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "weixin-js-sdk": "^1.6.5"
  },
  "pnpm": {
    "overrides": {
      "@hopeio/utils": "link:../../../../../Library/pnpm/global/5/node_modules/@hopeio/utils"
    }
  }
}