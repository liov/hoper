{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "node": "v22.0.0",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "protoc": "node ../../proto/generate.js grpc-web",
    "wasm:build": "wasm-pack build ../../server/rust/wasm --target web",
    "wasm:link": "pnpm link ../../server/rust/wasm/pkg",
    "dev": "vite --config vite.config.ts --mode dev",
    "build": "run-p type-check build-only",
    "preview": "vite preview --config vite.config.ts --port 4173",
    "test:unit": "vitest --environment jsdom",
    "build-only": "vite build --config vite.config.ts --mode prod",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "diamon": "pnpm link @hopeio/utils"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@hopeio/utils": "^0.0.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.15.0",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "grpc-web": "^2.0.2",
    "js-cookie": "^3.0.5",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "qs": "^6.15.1",
    "responsive-storage": "^2.2.0",
    "spark-md5": "^3.0.2",
    "vant": "^4.9.24",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-icons/ep": "^1.2.12",
    "@iconify-icons/ri": "^1.2.10",
    "@iconify-json/logos": "^1.2.11",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "boxen": "^8.0.1",
    "code-inspector-plugin": "^1.5.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "gradient-string": "^3.0.0",
    "jsdom": "^29.0.2",
    "less": "^4.6.4",
    "prettier": "^3.8.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "terser": "^5.46.1",
    "ts-proto": "^2.11.6",
    "typescript": "^6.0.2",
    "unplugin-vue-components": "32.0.0",
    "vite": "^8.0.8",
    "vite-plugin-cdn-import": "^1.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
