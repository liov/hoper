{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "sourceMap": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@gen/*": [
        "./gen/*"
      ]
    },
    "outDir": "dist",
    "lib": [
      "esnext",
      "dom"
    ],
    "types": [
      "@dcloudio/types",
      "@types/wechat-miniprogram",
      "wot-design-uni/global.d.ts",
      "@uni-helper/vite-plugin-uni-pages"
    ]
  },
  "vueCompilerOptions": {
    "target": 3,
    "nativeTags": [
      "block",
      "template",
      "component",
      "slot"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.vue",
    "src/**/*.json",
    "gen/**/*.ts"
  ]
}