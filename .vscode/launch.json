{
	// 使用 IntelliSense 了解相关属性。
	// 悬停以查看现有属性的描述。
	// 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "flutter:app:debug",
			"cwd": "${workspaceFolder}/client/app",
			"request": "launch",
			"type": "dart",
			"program": "lib/main.dart",
			"flutterMode": "debug"
		},
		{
			"name": "flutter:app:profile",
			"cwd": "${workspaceFolder}/client/app",
			"request": "launch",
			"type": "dart",
			"program": "lib/main.dart",
			"flutterMode": "profile"
		},
		{
			"name": "flutter:app:release",
			"cwd": "${workspaceFolder}/client/app",
			"request": "launch",
			"type": "dart",
			"program": "lib/main.dart",
			"flutterMode": "release"
		},
		{
			"name": "go:hoper",
			"cwd": "${workspaceFolder}/server/go",
			"request": "launch",
			"type": "go",
			"program": "${workspaceFolder}/server/go/main.go",
			"args": ["-c", "config/config.toml"],
			"env": {
				"OTEL_EXPORTER_OTLP_METRICS_ENDPOINT": "http://8.222.139.120:8428/opentelemetry/v1/metrics",
				"OTEL_EXPORTER_OTLP_LOGS_ENDPOINT": "http://8.222.139.120:9428/insert/opentelemetry/v1/logs",
				"OTEL_EXPORTER_OTLP_TRACES_ENDPOINT": "http://8.222.139.120:10428/insert/opentelemetry/v1/traces"
			}
		},
		{
			"name": "go:cherry",
			"cwd": "${workspaceFolder}/thirdparty/cherry/_example",
			"request": "launch",
			"type": "go",
			"program": "${workspaceFolder}/thirdparty/cherry/_example/user"
		},
		{
			"name": "go:pick:std",
			"cwd": "${workspaceFolder}/thirdparty/pick/_example/std",
			"request": "launch",
			"type": "go",
			"program": "${workspaceFolder}/thirdparty/pick/_example/std"
		},
		{
			"name": "go:pick:gin",
			"cwd": "${workspaceFolder}/thirdparty/pick/_example/gin",
			"request": "launch",
			"type": "go",
			"program": "${workspaceFolder}/thirdparty/pick/_example/gin"
		},
		{
			"name": "go:pick:fiber",
			"cwd": "${workspaceFolder}/thirdparty/pick/_example/fiber",
			"request": "launch",
			"type": "go",
			"program": "${workspaceFolder}/thirdparty/pick/_example/fiber"
		},
		{
			"name": "rust:rfv",
			"cwd": "${workspaceFolder}/server/rust/rfv",
			"request": "launch",
			"type": "lldb",
			"cargo": { "args": ["build", "--bin", "rfv"] }
		},
		{
			"name": "rust:message",
			"cwd": "${workspaceFolder}/server/rust/message",
			"request": "launch",
			"type": "lldb",
			"cargo": { "args": ["build", "--bin", "message"] }
		},
		{
			"name": "vue:web",
			"cwd": "${workspaceFolder}/client/web",
			"request": "launch",
			"type": "chrome",
			"url": "http://localhost:8080",
			"webRoot": "${workspaceFolder}/client/web/src",
			"preLaunchTask": "pnpm run h5:dev"
		},
		{
			"name": "uniapp",
			"cwd": "${workspaceFolder}/client/uniapp",
			"request": "launch",
			"type": "chrome",
			"url": "http://localhost:8080",
			"webRoot": "${workspaceFolder}/client/uniapp/src",
			"preLaunchTask": "pnpm run dev"
		}
	]
}