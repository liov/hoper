{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "hoper protogen",
			"type": "shell",
			"options": {
                "cwd": "${workspaceFolder}/server/go"
            },
			"command": "protogen",
			"args": [
				"go",
				"-d",
				"-e",
				"-w",
				"-v",
				"-i",
				"../../proto"
			],
			"runOptions": {
				"runOn": "folderOpen",
			}
		},
		{
			"label": "app release",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/client/app"
			},
			"command": "flutter",
			"args": ["build", "apk", "--release"],
		}
	]
}